rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /reports/{reportId} {
      // Só permite ler/excluir um relatório que já pertence ao usuário autenticado
      allow read, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // Criação: precisa pertencer ao próprio usuário e respeitar o schema básico
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && isValidReport(request.resource.data);

      // Atualização: o relatório já precisa ser do usuário, o userId não pode ser trocado,
      // e o novo conteúdo também precisa respeitar o schema básico
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && isValidReport(request.resource.data);
    }

    // Validações de schema compartilhadas entre create e update
    function isValidReport(data) {
      return data.evento is string && data.evento.size() > 0 && data.evento.size() <= 300
        && data.local is string && data.local.size() > 0 && data.local.size() <= 300
        && data.responsavel is string && data.responsavel.size() > 0 && data.responsavel.size() <= 200
        && data.conferidoPor is string && data.conferidoPor.size() > 0 && data.conferidoPor.size() <= 200
        && data.descricao is string && data.descricao.size() > 0 && data.descricao.size() <= 10000
        && (!('participantes' in data) || (data.participantes is string && data.participantes.size() <= 5000))
        && data.data is string && data.data.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.hora is string && data.hora.matches('^[0-9]{2}:[0-9]{2}$')
        && (!('fotoUrl' in data) || (data.fotoUrl is string && data.fotoUrl.size() <= 2000))
        && (!('fotoDriveId' in data) || (data.fotoDriveId is string && data.fotoDriveId.size() <= 200));
    }
  }
}
